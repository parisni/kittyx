#!/usr/bin/env bash
set -eo pipefail

export SHELL="$(command -v bash)"

# Copy Git URL for current file/cursor line to clipboard
# Usage: kittyx-git-url-copy <file> [line_number]

FILE="$1"
LINE_NUMBER="$2"

if [[ -z "$FILE" ]]; then
  echo "Error: Must provide a file path."
  exit 1
fi

# Generate the URL
URL=$(kittyx-git-url "$FILE" "$LINE_NUMBER")

if [[ $? -eq 0 && -n "$URL" ]]; then
  # Copy to clipboard using multiple methods for compatibility.
  # Prefer wl-copy: clipboard managers like copyq monitor the system
  # clipboard and add the entry to their history automatically, which
  # avoids races between `copyq add`/`copyq copy` and silent dedup of
  # identical items in the history tab.
  if command -v wl-copy >/dev/null 2>&1; then
    printf %s "$URL" | wl-copy
  elif command -v copyq >/dev/null 2>&1; then
    printf %s "$URL" | tee >(copyq add -) | copyq copy - >/dev/null 2>&1
  elif command -v xclip >/dev/null 2>&1; then
    printf %s "$URL" | xclip -selection clipboard
  else
    echo "Error: No clipboard utility found (wl-copy, copyq, or xclip required)" >&2
    exit 1
  fi

  echo "Copied to clipboard: $URL"
else
  echo "Error: Failed to generate URL"
  exit 1
fi
